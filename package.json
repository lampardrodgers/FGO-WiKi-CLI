{
  "name": "fgo-agent",
  "version": "0.1.0",
  "description": "FGO full-data CLI and MCP knowledge agent for Atlas Academy and Mooncell data.",
  "type": "module",
  "bin": {
    "fgo": "./dist/src/cli.js",
    "fgo-agent": "./dist/src/agent-cli.js",
    "fgo-mcp": "./dist/src/mcp-server.js"
  },
  "files": [
    "dist",
    "README.md",
    "AGENTS.md"
  ],
  "scripts": {
