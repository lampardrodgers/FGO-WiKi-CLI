    "start:mcp": "node --no-warnings=ExperimentalWarning dist/src/mcp-server.js"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
